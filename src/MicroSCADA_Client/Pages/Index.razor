@page "/"
@inject IOpcUaService OpcService
@inject ITagHistoryService History
@inject IDiagnosticsService Diagnostics
@inject IConfiguration Configuration
@implements IDisposable

<PageTitle>MicroSCADA</PageTitle>

@if (!OpcService.IsConnected)
{
    <MudPaper Class="pa-4" Style="max-width: 500px;">
        <MudText Class="mb-4">Enter OPC UA server endpoint to connect</MudText>
        <MudTextField @bind-Value="_endpointUrl" Label="OPC UA Endpoint" Variant="Variant.Outlined" />
        <MudButton OnClick="ConnectAsync" Variant="Variant.Filled" Color="Color.Primary" Class="mt-4"
            Disabled="_connecting">
            @if (_connecting)
            {
                <MudProgressCircular Size="Size.Small" Indeterminate="true" Class="ms-n1" />
                <MudText Class="ms-2">Connecting...</MudText>
            }
            else
            {
                <MudText>Connect</MudText>
            }
        </MudButton>
        @if (_errorMessage != null)
        {
            <MudAlert Severity="Severity.Error" Class="mt-4">@_errorMessage</MudAlert>
        }
    </MudPaper>
}
else
{
    <MudGrid Spacing="0" Class="scada-outer-grid">
        <MudItem xs="4" Class="d-flex">
            <MudPaper Outlined="true" Class="scada-card pa-4 d-flex flex-column flex-grow-1">
                <div class="scada-eyebrow-row">
                    <div class="scada-eyebrow">ADDRESS SPACE</div>
                    <MudButton OnClick="DisconnectAsync" Variant="Variant.Outlined" Color="Color.Error"
                        Size="Size.Small" StartIcon="@Icons.Material.Filled.PowerSettingsNew">
                        Disconnect
                    </MudButton>
                </div>
                <div class="tree-compact flex-grow-1" style="overflow-y: auto; min-height: 0;">
                    <MudTreeView T="string" Items="_treeItems" ServerData="LoadChildNodes"
                        SelectionMode="SelectionMode.MultiSelection" @bind-SelectedValues="_selectedNodeIds">
                        <ItemTemplate>
                            <MudTreeViewItem T="string" Value="@context.Value" Icon="@context.Icon"
                                IconColor="@GetIconColor(context.Value)"
                                Text="@context.Text" />
                        </ItemTemplate>
                    </MudTreeView>
                </div>
            </MudPaper>
        </MudItem>
        <MudItem xs="8">
            <MudStack Spacing="4">
                <div class="scada-row-2col">
                <MudPaper Outlined="true" Class="scada-card pa-4" Style="flex: 1 1 50%; min-width: 0;">
                    <div class="scada-eyebrow-row">
                        <div class="scada-eyebrow">SUBSCRIPTION DATA</div>
                        <div class="d-flex align-center gap-3">
                            <MudText Typo="Typo.caption" Class="mud-text-secondary">
                                Selected: @(_selectedNodeIds?.Count ?? 0)
                            </MudText>
                            <MudButton OnClick="SubscribeAsync" Variant="Variant.Text" Color="Color.Info"
                                Size="Size.Small" Class="scada-action-btn"
                                Disabled="@(_subscribing || (_selectedNodeIds?.Count ?? 0) == 0)">
                                @if (_subscribing)
                                {
                                    <MudProgressCircular Size="Size.Small" Indeterminate="true" Class="ms-n1" />
                                    <MudText Class="ms-2">Subscribing...</MudText>
                                }
                                else
                                {
                                    <MudText>Subscribe</MudText>
                                }
                            </MudButton>
                        </div>
                    </div>
                    @if (_subscribedTags.Count == 0)
                    {
                        <MudText Typo="Typo.body2" Class="mud-text-secondary">
                            @(_subscriptionError ?? "No subscriptions active")
                        </MudText>
                    }
                    else
                    {
                        <MudSimpleTable Dense="true" Hover="true" Style="table-layout: fixed; width: 100%;">
                                <thead>
                                    <tr>
                                        <th>Tag</th>
                                        <th style="width: 9ch; text-align: right;">Value</th>
                                        <th style="width: 13ch;">Timestamp</th>
                                    </tr>
                                </thead>
                                <tbody>
                                    @foreach (var tag in _subscribedTags.Values)
                                    {
                                        <tr>
                                            <td class="sub-tag">
                                                <MudTooltip Text="@tag.NodeId" Placement="Placement.Top">
                                                    <span>@tag.DisplayName</span>
                                                </MudTooltip>
                                            </td>
                                            <td class="sub-val">@FormatValue(tag.Value)</td>
                                            <td class="sub-ts">@(tag.Timestamp?.ToString("HH:mm:ss.fff") ?? "—")</td>
                                        </tr>
                                    }
                                </tbody>
                            </MudSimpleTable>
                        }
                </MudPaper>
                <MudPaper Outlined="true" Class="scada-card pa-4" Style="flex: 1 1 50%; min-width: 0;">
                    <div class="scada-eyebrow-row">
                        <div class="scada-eyebrow">DIAGNOSTICS</div>
                    </div>
                    @{
                        var d = _diag;
                    }
                    <div class="scada-pill-strip mb-2">
                        <span class="scada-pill @PillClassForState(d.ConnectionState)">
                            <span class="scada-pill-dot"></span>@d.ConnectionState
                        </span>
                        <span class="scada-pill @(d.MonitoredItemCount > 0 ? "pill-info" : "")">
                            @d.MonitoredItemCount item@(d.MonitoredItemCount == 1 ? "" : "s")
                        </span>
                        <span class="scada-pill @PillClassForLatency(d.KeepAliveLatencyMs)">
                            @(d.KeepAliveLatencyMs.HasValue ? $"{d.KeepAliveLatencyMs:F0}ms keep-alive" : "— keep-alive")
                        </span>
                        @if (d.PublishingIntervalMs.HasValue)
                        {
                            <span class="scada-pill">Publish @(d.PublishingIntervalMs)ms</span>
                        }
                        @if (d.MissedKeepAliveCount > 0)
                        {
                            <span class="scada-pill pill-error">@d.MissedKeepAliveCount missed</span>
                        }
                    </div>
                    <table class="diag-table" aria-label="Session diagnostics">
                        <tbody>
                            <tr><td>State</td><td class="@DiagStateClass(d.ConnectionState)">@d.ConnectionState</td></tr>
                            <tr><td>Endpoint</td><td title="@d.EndpointUrl">@(d.EndpointUrl ?? "—")</td></tr>
                            <tr><td>Security</td><td>@(ShortSecurity(d.SecurityPolicyUri))</td></tr>
                            <tr><td>Uptime</td><td class="diag-accent">@(d.SessionUptime.HasValue ? FormatUptime(d.SessionUptime.Value) : "—")</td></tr>
                            <tr><td>Monitored items</td><td class="@(d.MonitoredItemCount > 0 ? "diag-ok" : null)">@d.MonitoredItemCount</td></tr>
                            <tr><td>Publish interval</td><td>@(d.PublishingIntervalMs.HasValue ? $"{d.PublishingIntervalMs} ms" : "—")</td></tr>
                            <tr><td>Last keep-alive</td><td>@FormatAge(d.LastKeepAliveUtc)</td></tr>
                            <tr><td>Keep-alive latency</td><td class="@DiagLatencyClass(d.KeepAliveLatencyMs)">@(d.KeepAliveLatencyMs.HasValue ? $"{d.KeepAliveLatencyMs:F0} ms" : "—")</td></tr>
                            <tr><td>Missed keep-alives</td><td class="@(d.MissedKeepAliveCount > 0 ? "diag-error" : null)">@d.MissedKeepAliveCount</td></tr>
                            <tr><td>Last notification</td><td>@FormatAge(d.LastNotificationUtc)</td></tr>
                            @if (!string.IsNullOrEmpty(d.LastError))
                            {
                                <tr><td>Last error</td><td class="diag-error">@d.LastError</td></tr>
                            }
                        </tbody>
                    </table>
                </MudPaper>
                </div>
            <MudPaper Outlined="true" Class="scada-card pa-4">
                <div class="scada-eyebrow-row">
                    <div class="scada-eyebrow">LIVE CHART</div>
                    <MudToggleGroup T="TimeSpan" @bind-Value="_chartWindow" Color="Color.Info"
                        Size="Size.Small" Class="scada-window-picker">
                        <MudToggleItem Value="@TimeSpan.FromSeconds(30)" Text="30s" />
                        <MudToggleItem Value="@TimeSpan.FromMinutes(1)" Text="1m" />
                        <MudToggleItem Value="@TimeSpan.FromMinutes(5)" Text="5m" />
                        <MudToggleItem Value="@TimeSpan.FromMinutes(15)" Text="15m" />
                    </MudToggleGroup>
                </div>

                @if (_subscribedTags.Count == 0)
                {
                    <MudText Typo="Typo.body2" Class="mud-text-secondary">
                        Subscribe to numeric tags to see the chart.
                    </MudText>
                }
                else
                {
                    <div class="scada-pill-strip mb-2">
                        @{
                            var tagIdx = 0;
                        }
                        @foreach (var nodeId in _subscribedTags.Keys)
                        {
                            var thisIdx = tagIdx % TagPaletteHex.Length;
                            var isCharted = _chartedTags.Contains(nodeId);
                            var nodeIdCapture = nodeId;
                            <button type="button"
                                    class="scada-tag-pill tag-@thisIdx @(isCharted ? "active" : "")"
                                    aria-pressed="@(isCharted ? "true" : "false")"
                                    @onclick="@(() => ToggleChartedTag(nodeIdCapture))">
                                <span class="scada-tag-dot"></span>
                                @GetDisplayName(nodeId)
                            </button>
                            tagIdx++;
                        }
                    </div>
                    @if (_capWarning)
                    {
                        <MudAlert Severity="Severity.Warning" Dense="true" Class="mb-2"
                            ShowCloseIcon="true" CloseIconClicked="@(() => _capWarning = false)">
                            Chart is capped at @ChartTagCap tags. Untoggle one to add another.
                        </MudAlert>
                    }

                    @if (_chartedTags.Count == 0)
                    {
                        <MudText Typo="Typo.body2" Class="mud-text-secondary">
                            Click a tag above to plot it.
                        </MudText>
                    }
                    else
                    {
                        <ApexCharts.ApexChart TItem="TagSample" Options="_chartOptions" @ref="_chart">
                            @foreach (var nodeId in _chartedTags)
                            {
                                <ApexCharts.ApexPointSeries TItem="TagSample"
                                    Items="@History.GetWindow(nodeId, _chartWindow)"
                                    Name="@GetDisplayName(nodeId)"
                                    SeriesType="ApexCharts.SeriesType.Line"
                                    XValue="@(s => ((DateTimeOffset)s.Ts).ToUnixTimeMilliseconds())"
                                    YValue="@(s => (decimal)s.Value)" />
                            }
                        </ApexCharts.ApexChart>
                    }
                }
            </MudPaper>
            </MudStack>
        </MudItem>
    </MudGrid>
}

<style>
    /* Theme tokens — swap here, cascade everywhere */
    :root {
        --scada-border: rgba(255, 255, 255, 0.08);
        --scada-subtle-bg: rgba(255, 255, 255, 0.05);
        --scada-hover-bg: rgba(255, 255, 255, 0.04);
        --scada-hover-border: rgba(255, 255, 255, 0.2);
        --scada-eyebrow-border: rgba(255, 255, 255, 0.05);
    }
    .mud-theme-light {
        --scada-border: rgba(15, 23, 42, 0.09);
        --scada-subtle-bg: rgba(15, 23, 42, 0.05);
        --scada-hover-bg: rgba(15, 23, 42, 0.04);
        --scada-hover-border: rgba(15, 23, 42, 0.16);
        --scada-eyebrow-border: rgba(15, 23, 42, 0.06);
    }

    /* Card — 1px subtle border */
    .scada-card.mud-paper-outlined {
        border-width: 1px;
        border-color: var(--scada-border);
        border-radius: 10px;
    }

    /* Section eyebrow headers */
    .scada-eyebrow {
        font-family: ui-monospace, SFMono-Regular, Menlo, monospace;
        font-size: 0.7rem;
        font-weight: 600;
        letter-spacing: 0.12em;
        text-transform: uppercase;
        color: var(--mud-palette-text-secondary);
        opacity: 0.78;
    }
    .scada-eyebrow-row {
        display: flex;
        align-items: center;
        justify-content: space-between;
        padding-bottom: 10px;
        margin-bottom: 14px;
        border-bottom: 1px solid var(--scada-eyebrow-border);
    }

    /* Outer grid — force 16px between tree and right column (matches inner gaps) */
    .scada-outer-grid.mud-grid {
        margin: -8px;
    }
    .scada-outer-grid.mud-grid > .mud-grid-item {
        padding: 8px;
    }

    /* Two-column flex row (subscription + diagnostics) */
    .scada-row-2col {
        display: flex;
        gap: 16px;
        align-items: stretch;
    }
    .scada-row-2col > .mud-paper { display: flex; flex-direction: column; }

    /* Named pattern: horizontal strip of pills */
    .scada-pill-strip {
        display: flex;
        flex-wrap: wrap;
        gap: 8px;
    }

    /* Status / diagnostic pills */
    .scada-pill {
        display: inline-flex;
        align-items: center;
        gap: 6px;
        height: 22px;
        padding: 0 10px;
        border-radius: 6px;
        font-family: ui-monospace, SFMono-Regular, Menlo, monospace;
        font-size: 0.72rem;
        font-weight: 500;
        background: var(--scada-subtle-bg);
        color: var(--mud-palette-text-secondary);
        white-space: nowrap;
        font-variant-numeric: tabular-nums;
    }
    .scada-pill-dot { width: 6px; height: 6px; border-radius: 50%; background: currentColor; }
    .scada-pill.pill-success { background: rgba(34, 211, 164, 0.14); color: var(--mud-palette-success); }
    .scada-pill.pill-info    { background: rgba(56, 189, 248, 0.14); color: var(--mud-palette-info); }
    .scada-pill.pill-warning { background: rgba(251, 191, 36, 0.14); color: var(--mud-palette-warning); }
    .scada-pill.pill-error   { background: rgba(244, 63, 94, 0.14); color: var(--mud-palette-error); }

    /* Chart tag pills — borderless tinted ghost when inactive, filled when active */
    .scada-tag-pill {
        display: inline-flex;
        align-items: center;
        gap: 6px;
        height: 22px;
        padding: 0 8px;
        border-radius: 5px;
        background: var(--scada-subtle-bg);
        border: 1px solid transparent;
        color: var(--mud-palette-text-secondary);
        font-family: ui-monospace, SFMono-Regular, Menlo, monospace;
        font-size: 0.7rem;
        font-weight: 500;
        letter-spacing: 0.01em;
        cursor: pointer;
        transition: background 0.15s, border-color 0.15s, color 0.15s;
    }
    .scada-tag-pill:hover { background: var(--scada-hover-bg); border-color: var(--scada-hover-border); }
    .scada-tag-pill .scada-tag-dot {
        width: 6px; height: 6px; border-radius: 50%;
        background: rgba(148, 163, 184, 0.6);
    }
    .scada-tag-pill.tag-0 { --tag-c: #38BDF8; --tag-rgb: 56, 189, 248; }
    .scada-tag-pill.tag-1 { --tag-c: #22D3A4; --tag-rgb: 34, 211, 164; }
    .scada-tag-pill.tag-2 { --tag-c: #FBBF24; --tag-rgb: 251, 191, 36; }
    .scada-tag-pill.tag-3 { --tag-c: #F472B6; --tag-rgb: 244, 114, 182; }
    .scada-tag-pill.tag-4 { --tag-c: #14B8A6; --tag-rgb: 20, 184, 166; }
    .scada-tag-pill.active {
        background: rgba(var(--tag-rgb), 0.15);
        border-color: rgba(var(--tag-rgb), 0.35);
        color: var(--tag-c);
    }
    .scada-tag-pill.active .scada-tag-dot { background: var(--tag-c); }

    /* Tree — density + monospace overrides */
    .tree-compact {
        font-size: 0.78rem;
        font-family: ui-monospace, SFMono-Regular, Menlo, Consolas, monospace;
    }
    .tree-compact .mud-treeview-item-content {
        min-height: 26px;
        padding-top: 1px;
        padding-bottom: 1px;
    }
    .tree-compact .mud-treeview-item-content .mud-typography {
        font-family: inherit;
    }
    .tree-compact .mud-icon-root { font-size: 1.2rem; }
    .tree-compact .mud-icon-root.mud-svg-icon { width: 1.2rem; height: 1.2rem; }

    /* Action button — tinted fill matching active-pill aesthetic */
    .mud-button.scada-action-btn {
        background-color: rgba(56, 189, 248, 0.14);
        color: var(--mud-palette-info);
        border: 1px solid rgba(56, 189, 248, 0.35);
        text-transform: none;
        font-family: ui-monospace, SFMono-Regular, Menlo, monospace;
        font-size: 0.75rem;
        font-weight: 600;
        letter-spacing: 0.02em;
    }
    .mud-button.scada-action-btn:hover {
        background-color: rgba(56, 189, 248, 0.22);
        border-color: rgba(56, 189, 248, 0.5);
    }
    .mud-button.scada-action-btn.mud-disabled,
    .mud-button.scada-action-btn:disabled {
        background-color: rgba(148, 163, 184, 0.08);
        color: var(--mud-palette-action-disabled);
        border-color: rgba(148, 163, 184, 0.15);
    }

    /* Window picker (MudToggleGroup) — tinted fill on active item */
    .scada-window-picker.mud-toggle-group .mud-toggle-item-selected {
        background-color: rgba(56, 189, 248, 0.15) !important;
        color: var(--mud-palette-info) !important;
    }
    .scada-window-picker.mud-toggle-group .mud-toggle-item {
        font-family: ui-monospace, SFMono-Regular, Menlo, monospace;
        font-size: 0.72rem;
        letter-spacing: 0.04em;
        min-width: 36px;
    }

    /* Subscription table cells */
    .sub-tag { overflow: hidden; text-overflow: ellipsis; white-space: nowrap; }
    .sub-val, .sub-ts {
        font-variant-numeric: tabular-nums;
        font-family: ui-monospace, SFMono-Regular, Menlo, monospace;
    }
    .sub-val { text-align: right; }

    /* Diagnostics table */
    .diag-table { width: 100%; font-size: 0.82rem; }
    .diag-table td { padding: 3px 4px; vertical-align: top; }
    .diag-table td:first-child {
        color: var(--mud-palette-text-secondary);
        width: 40%;
        font-size: 0.72rem;
        letter-spacing: 0.02em;
    }
    .diag-table td:last-child {
        font-variant-numeric: tabular-nums;
        font-family: ui-monospace, SFMono-Regular, Menlo, monospace;
        overflow: hidden;
        text-overflow: ellipsis;
        max-width: 0;
        white-space: nowrap;
    }
    .diag-ok { color: var(--mud-palette-success); }
    .diag-warn { color: var(--mud-palette-warning); }
    .diag-error { color: var(--mud-palette-error); }
    .diag-accent { color: var(--mud-palette-info); }
    .diag-muted { color: var(--mud-palette-text-secondary); }
</style>

@code {
    private string _endpointUrl = "";
    private bool _connecting;
    private bool _subscribing;
    private string? _errorMessage;
    private List<TreeItemData<string>> _treeItems = new();
    private IReadOnlyCollection<string>? _selectedNodeIds;
    private Dictionary<string, SubscribedTag> _subscribedTags = new();
    private string? _subscriptionError;
    private Dictionary<string, string?> _nodeValues = new();
    private Dictionary<string, string> _nodeDisplayNames = new();
    private HashSet<string> _nodeFolders = new();
    private HashSet<string> _nodeReadable = new();

    // Custom icons matching the hero aesthetic — simple blue-rect folder + outlined leaf box
    private const string FolderIconSvg =
        @"<path d=""M3 7a2 2 0 0 1 2-2h5l2 2h7a2 2 0 0 1 2 2v8a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2V7Z"" fill=""currentColor"" fill-opacity=""0.32""/>" +
        @"<path d=""M3 7a2 2 0 0 1 2-2h5l2 2h3v3H3V7Z"" fill=""currentColor"" fill-opacity=""0.6""/>";

    private const string LeafIconSvg =
        @"<rect x=""5"" y=""7"" width=""14"" height=""10"" rx=""2"" fill=""none"" stroke=""currentColor"" stroke-width=""1.6""/>";

    private const int ChartTagCap = 4;
    private static readonly string[] TagPaletteHex =
    {
        "#38BDF8", "#22D3A4", "#FBBF24", "#F472B6", "#14B8A6"
    };
    private TimeSpan _chartWindow = TimeSpan.FromMinutes(1);
    private List<string> _chartedTags = new();
    private bool _capWarning;
    private ApexCharts.ApexChart<TagSample>? _chart;
    private DiagnosticsSnapshot _diag = default!;
    private readonly ApexCharts.ApexChartOptions<TagSample> _chartOptions = new()
    {
        Chart = new ApexCharts.Chart
        {
            Animations = new ApexCharts.Animations { Enabled = false },
            Toolbar = new ApexCharts.Toolbar { Show = false },
            Height = 320,
            Background = "transparent",
            ForeColor = "var(--mud-palette-text-primary)"
        },
        Grid = new ApexCharts.Grid
        {
            BorderColor = "var(--mud-palette-lines-default)",
            Padding = new ApexCharts.Padding { Bottom = 0, Top = 0 }
        },
        Legend = new ApexCharts.Legend { Show = false },
        Stroke = new ApexCharts.Stroke { Curve = ApexCharts.Curve.Smooth, Width = 2 },
        Tooltip = new ApexCharts.Tooltip { Enabled = true, X = new ApexCharts.TooltipX { Format = "HH:mm:ss" } },
        Xaxis = new ApexCharts.XAxis
        {
            Type = ApexCharts.XAxisType.Datetime,
            Labels = new ApexCharts.XAxisLabels
            {
                Rotate = 0,
                DatetimeUTC = false,
                HideOverlappingLabels = true
            }
        },
        Yaxis = new List<ApexCharts.YAxis>
        {
            new ApexCharts.YAxis
            {
                Labels = new ApexCharts.YAxisLabels
                {
                    Formatter = "function(val) { return Number(val).toPrecision(5); }"
                }
            }
        }
    };

    private void RefreshChartColors()
    {
        var subscribedOrdered = _subscribedTags.Keys.ToList();
        _chartOptions.Colors = _chartedTags
            .Select(id =>
            {
                var idx = subscribedOrdered.IndexOf(id);
                return idx >= 0 ? TagPaletteHex[idx % TagPaletteHex.Length] : TagPaletteHex[0];
            })
            .ToList();
    }

    private class SubscribedTag
    {
        public string NodeId { get; init; } = "";
        public string DisplayName { get; init; } = "";
        public string? Value { get; set; }
        public DateTime? Timestamp { get; set; }
    }

    private string? GetNodeValue(string? nodeId) =>
        nodeId != null && _nodeValues.TryGetValue(nodeId, out var val) ? val : null;

    private Color GetIconColor(string? nodeId)
    {
        if (string.IsNullOrEmpty(nodeId)) return Color.Info;
        if (_nodeFolders.Contains(nodeId)) return Color.Info;
        return _nodeReadable.Contains(nodeId) ? Color.Success : Color.Error;
    }

    private static string FormatValue(string? raw)
    {
        if (string.IsNullOrEmpty(raw)) return "—";
        if (double.TryParse(raw, System.Globalization.NumberStyles.Float, System.Globalization.CultureInfo.InvariantCulture, out var d))
            return d.ToString("G3", System.Globalization.CultureInfo.InvariantCulture);
        return raw;
    }

    protected override void OnInitialized()
    {
        _endpointUrl = Configuration["OpcUa:DefaultEndpoint"] ?? "opc.tcp://localhost:4840";
        _diag = Diagnostics.Current;
        OpcService.DataChanged += OnDataChanged;
        History.HistoryUpdated += OnHistoryUpdated;
        Diagnostics.Updated += OnDiagnosticsUpdated;
    }

    private void OnDiagnosticsUpdated(DiagnosticsSnapshot snapshot)
    {
        _diag = snapshot;
        InvokeAsync(StateHasChanged);
    }

    private static string ShortSecurity(string? uri)
    {
        if (string.IsNullOrEmpty(uri)) return "—";
        var idx = uri.LastIndexOf('#');
        return idx >= 0 ? uri[(idx + 1)..] : uri;
    }

    private static string FormatUptime(TimeSpan t)
    {
        if (t.TotalHours >= 1) return $"{(int)t.TotalHours}h {t.Minutes}m";
        if (t.TotalMinutes >= 1) return $"{t.Minutes}m {t.Seconds}s";
        return $"{t.Seconds}s";
    }

    private static string DiagStateClass(ConnectionState s) => s switch
    {
        ConnectionState.Connected => "diag-ok",
        ConnectionState.Faulted => "diag-warn",
        _ => "diag-muted"
    };

    private static string? DiagLatencyClass(double? ms)
    {
        if (!ms.HasValue) return null;
        if (ms.Value < 100) return "diag-ok";
        if (ms.Value < 500) return "diag-warn";
        return "diag-error";
    }

    private static string PillClassForState(ConnectionState s) => s switch
    {
        ConnectionState.Connected => "pill-success",
        ConnectionState.Faulted => "pill-warning",
        _ => ""
    };

    private static string PillClassForLatency(double? ms)
    {
        if (!ms.HasValue) return "";
        if (ms.Value < 100) return "pill-success";
        if (ms.Value < 500) return "pill-warning";
        return "pill-error";
    }

    private static string FormatAge(DateTime? utc)
    {
        if (!utc.HasValue) return "—";
        var age = DateTime.UtcNow - utc.Value;
        if (age.TotalSeconds < 1) return "just now";
        if (age.TotalSeconds < 60) return $"{(int)age.TotalSeconds}s ago";
        if (age.TotalMinutes < 60) return $"{(int)age.TotalMinutes}m ago";
        return utc.Value.ToLocalTime().ToString("HH:mm:ss");
    }

    private string GetDisplayName(string nodeId)
        => _nodeDisplayNames.TryGetValue(nodeId, out var name) ? name : nodeId;

    private bool _chartDirty;

    private void OnHistoryUpdated()
    {
        _chartDirty = true;
        InvokeAsync(StateHasChanged);
    }

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (_chartDirty && _chart != null)
        {
            _chartDirty = false;
            try { await _chart.UpdateSeriesAsync(animate: false); }
            catch { /* chart may be mid-init or disposing; next tick will retry */ }
        }
    }

    private void ToggleChartedTag(string nodeId)
    {
        if (_chartedTags.Contains(nodeId))
        {
            _chartedTags.Remove(nodeId);
            _capWarning = false;
        }
        else if (_chartedTags.Count >= ChartTagCap)
        {
            _capWarning = true;
            return;
        }
        else
        {
            _chartedTags.Add(nodeId);
        }
        RefreshChartColors();
        _chartDirty = true;
    }

    private async Task ConnectAsync()
    {
        _connecting = true;
        _errorMessage = null;
        try
        {
            await OpcService.ConnectAsync(_endpointUrl);
            _treeItems = new List<TreeItemData<string>>
            {
                new TreeItemData<string>
                {
                    Value = "",
                    Text = "Objects",
                    Icon = Icons.Material.Filled.Folder,
                    Expandable = true
                }
            };
        }
        catch (Exception ex)
        {
            _errorMessage = $"Connection failed: {ex.Message}";
        }
        finally
        {
            _connecting = false;
        }
    }

    private async Task DisconnectAsync()
    {
        foreach (var nodeId in _subscribedTags.Keys)
            History.Untrack(nodeId);
        _chartedTags.Clear();

        await OpcService.DisconnectAsync();
        _treeItems.Clear();
        _selectedNodeIds = null;
        _nodeValues.Clear();
        _nodeDisplayNames.Clear();
        _nodeFolders.Clear();
        _nodeReadable.Clear();
        _subscribedTags.Clear();
        _subscriptionError = null;
    }

    private async Task<IReadOnlyCollection<TreeItemData<string>>> LoadChildNodes(string parentNodeId)
    {
        try
        {
            var browseNodeId = string.IsNullOrEmpty(parentNodeId) ? null : parentNodeId;
            var nodes = await OpcService.BrowseAsync(browseNodeId);
            foreach (var n in nodes)
            {
                _nodeValues[n.NodeId] = n.Value;
                _nodeDisplayNames[n.NodeId] = n.DisplayName;
                if (n.HasChildren) _nodeFolders.Add(n.NodeId);
                else if (n.Value != null) _nodeReadable.Add(n.NodeId);
            }
            return nodes.Select(n => new TreeItemData<string>
            {
                Value = n.NodeId,
                Text = n.DisplayName,
                Icon = n.HasChildren ? FolderIconSvg : LeafIconSvg,
                Expandable = n.HasChildren
            }).ToList();
        }
        catch (Exception ex)
        {
            return new List<TreeItemData<string>>
            {
                new() { Text = $"Error: {ex.Message}", Icon = Icons.Material.Filled.Error }
            };
        }
    }

    private async Task SubscribeAsync()
    {
        if (_selectedNodeIds == null || _selectedNodeIds.Count == 0) return;

        _subscribing = true;
        _subscriptionError = null;
        try
        {
            _subscribedTags = _selectedNodeIds.ToDictionary(
                id => id,
                id => new SubscribedTag
                {
                    NodeId = id,
                    DisplayName = _nodeDisplayNames.TryGetValue(id, out var name) ? name : id,
                    Value = _nodeValues.TryGetValue(id, out var v) ? v : null
                });
            foreach (var id in _selectedNodeIds)
                History.Track(id);
            _chartedTags = _selectedNodeIds.Take(ChartTagCap).ToList();
            RefreshChartColors();
            await OpcService.SubscribeAsync(_selectedNodeIds);
        }
        catch (Exception ex)
        {
            _subscriptionError = $"Subscription error: {ex.Message}";
            _subscribedTags.Clear();
        }
        finally
        {
            _subscribing = false;
        }
    }

    private void OnDataChanged(string nodeId, string value)
    {
        InvokeAsync(() =>
        {
            if (_subscribedTags.TryGetValue(nodeId, out var tag))
            {
                tag.Value = value;
                tag.Timestamp = DateTime.Now;
            }
            StateHasChanged();
        });
    }

    public void Dispose()
    {
        OpcService.DataChanged -= OnDataChanged;
        History.HistoryUpdated -= OnHistoryUpdated;
        Diagnostics.Updated -= OnDiagnosticsUpdated;
    }
}
